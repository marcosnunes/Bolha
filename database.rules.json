{
  "rules": {
    "posts": {
      ".read": "auth != null",
      ".indexOn": ["createdAt"],
      "$postId": {
        ".write": "auth != null && ( (!data.exists() && newData.child('authorId').val() === auth.uid) || (data.exists() && data.child('authorId').val() === auth.uid) )",
        ".validate": "!data.exists() ? newData.hasChildren(['authorId', 'authorNickname', 'createdAt']) && newData.child('authorId').val() === auth.uid : true",
        "authorId": { ".write": false },
        "authorNickname": { ".write": false },
        "authorPhotoURL": { ".write": false },
        "createdAt": { ".write": false },
        "isNSFW": { ".write": false },
        "mediaURL": { ".write": false },
        "mediaType": { ".write": false },
        "textContent": {
          ".write": "auth != null && root.child('posts').child($postId).child('authorId').val() === auth.uid",
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 10000"
        },
        "editedAt": {
          ".write": "auth != null && root.child('posts').child($postId).child('authorId').val() === auth.uid"
        },
        "likes": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.isBoolean() || !newData.exists()"
          }
        },
        "dislikes": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.isBoolean() || !newData.exists()"
          }
        },
        "comments": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$commentId": {
            ".write": "auth != null && (!data.exists() || root.child('posts').child($postId).child('comments').child($commentId).child('authorId').val() === auth.uid)",
            "authorId": { ".write": false },
            "authorNickname": { ".write": false },
            "authorPhotoURL": { ".write": false },
            "createdAt": { ".write": false },
            "textContent": {
              ".write": "auth != null && root.child('posts').child($postId).child('comments').child($commentId).child('authorId').val() === auth.uid",
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 5000"
            },
            "editedAt": {
              ".write": "auth != null && root.child('posts').child($postId).child('comments').child($commentId).child('authorId').val() === auth.uid"
            },
            "likes": {
              ".read": "auth != null",
              ".write": "auth != null",
              "$uid": {
                ".write": "auth != null && auth.uid === $uid",
                ".validate": "newData.isBoolean() || !newData.exists()"
              }
            }
          }
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "hiddenUsers": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",
          "$targetUid": {
            ".validate": "newData.isBoolean() || !newData.exists()",
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "profiles": {
      ".read": "auth != null",
      ".indexOn": ["createdAt"],
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        "nickname": {
          ".validate": "newData.isString() && newData.val().length >= 3 && newData.val().length <= 50"
        },
        "photoURL": {
          ".validate": "newData.isString() || !newData.exists()"
        },
        "isVerified": { 
          ".write": false 
        },
        "createdAt": { 
          ".write": false 
        }
      }
    },
    "invites": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$token": {
        ".validate": "newData.hasChildren(['invitedBy', 'status', 'createdAt']) && (newData.child('status').val() === 'pending' || newData.child('status').val() === 'completed')",
        ".write": "auth != null"
      }
    },
    "verificationTokens": {
      ".read": false,
      ".write": false
    }
  }
}
