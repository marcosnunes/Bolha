{
  "rules": {
    "posts": {
      ".read": "auth != null",
      ".indexOn": ["createdAt", "lastActivityAt"], 
      "$postId": {
        ".write": "auth != null && ( (!data.exists() && newData.child('authorId').val() === auth.uid) || (data.exists() && data.child('authorId').val() === auth.uid) )",
        ".validate": "newData.hasChildren(['authorId', 'authorNickname', 'createdAt']) && (!data.exists() || newData.child('authorId').val() === data.child('authorId').val())",
        "textContent": {
          ".write": "auth != null && root.child('posts').child($postId).child('authorId').val() === auth.uid"
        },
        "lastActivityAt": {
          ".write": "auth != null",
          ".validate": "newData.isNumber()"
        },
        "likes": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.isNumber() || newData.val() === true"
          }
        },
        "dislikes": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "comments": {
          ".read": "auth != null",
          "$commentId": {
            ".write": "auth != null && ( (!data.exists() && newData.child('authorId').val() === auth.uid) || (data.exists() && data.child('authorId').val() === auth.uid) )",
            ".validate": "newData.hasChildren(['authorId', 'authorNickname', 'textContent', 'createdAt'])",
            "textContent": {
              ".write": "auth != null && root.child('posts').child($postId).child('comments').child($commentId).child('authorId').val() === auth.uid"
            },
            "editedAt": {
              ".write": "auth != null && root.child('posts').child($postId).child('comments').child($commentId).child('authorId').val() === auth.uid"
            },
            "likes": {
              ".read": "auth != null",
              "$uid": {
                ".write": "auth != null && auth.uid === $uid",
                ".validate": "newData.isNumber() || newData.val() === true"
              }
            }
          }
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        "online": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "profiles": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "invites": {
      ".read": "true",
      ".write": "auth != null"
    },
    "verificationTokens": {
      ".read": false,
      ".write": false
    }
  }
}
