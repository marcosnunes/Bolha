{
  "rules": {
    "posts": {
      ".read": "auth != null",
      ".indexOn": ["createdAt"], 
      "$postId": {
        ".write": "auth != null && ( (!data.exists() && newData.child('authorId').val() === auth.uid) || (data.exists() && data.child('authorId').val() === auth.uid) )",
        ".validate": "!data.exists() ? newData.hasChildren(['authorId', 'authorNickname', 'createdAt']) && newData.child('authorId').val() === auth.uid : data.child('authorId').val() === auth.uid",
        "likes": {
          ".write": "auth != null",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        },
        "comments": {
          ".read": "auth != null",
          ".write": "auth != null",
          "$commentId": {
            ".write": "auth != null && ( (!data.exists() && newData.child('authorId').val() === auth.uid) || (data.exists() && data.child('authorId').val() === auth.uid) )",
            ".validate": "!data.exists() ? (newData.child('authorId').val() === auth.uid && newData.child('authorNickname').exists() && newData.child('textContent').exists() && newData.child('createdAt').exists()) : true",
            "authorId": {
              ".write": false
            },
            "authorNickname": {
              ".write": false
            },
            "authorPhotoURL": {
              ".write": false
            },
            "textContent": {
              ".write": "auth != null && root.child('posts').child($postId).child('comments').child($commentId).child('authorId').val() === auth.uid"
            },
            "createdAt": {
              ".write": false
            },
            "editedAt": {
              ".write": "auth != null && root.child('posts').child($postId).child('comments').child($commentId).child('authorId').val() === auth.uid"
            },
            "likes": {
              ".write": "auth != null",
              "$uid": {
                ".write": "auth != null && auth.uid === $uid"
              }
            }
          }
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "profiles": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "invites": {
      ".read": "true",
      ".write": "auth != null"
    },
    "verificationTokens": {
      ".read": false,
      ".write": false
    }
  }
}
