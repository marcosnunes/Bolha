# Email configuration - Firebase Cloud Functions
# INSTRUÇÃO: Copie este arquivo para .env e preencha com suas credenciais reais
# O arquivo .env será ignorado pelo git (contém dados sensíveis)
#
# Para configurar:
# 1. Crie um arquivo .env nesta pasta
# 2. Preencha EMAIL_USER e EMAIL_PASSWORD com seus valores reais
# 3. O arquivo será carregado automaticamente durante desenvolvimento/deploy

EMAIL_USER=seu-email@gmail.com
EMAIL_PASSWORD=sua-app-password-16-caracteres
